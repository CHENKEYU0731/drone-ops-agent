{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "preflight-check",
  "description": "离线飞行前检查 skill 契约。",
  "type": "object",
  "properties": {
    "skill_name": {
      "const": "preflight-check"
    },
    "skill_version": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": ["GO", "REVIEW_REQUIRED", "NO_GO"]
    },
    "blocking_items": {
      "type": "array"
    },
    "warnings": {
      "type": "array"
    },
    "human_review_required": {
      "type": "boolean"
    }
  },
  "required": [
    "skill_name",
    "skill_version",
    "inputs",
    "outputs",
    "status",
    "blocking_items",
    "warnings",
    "human_review_required"
  ]
}
