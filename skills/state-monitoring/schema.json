{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "state-monitoring",
  "description": "离线 telemetry 回放状态监控 skill 输出契约。",
  "type": "object",
  "properties": {
    "summary": {
      "type": "object",
      "required": [
        "id",
        "timestamp",
        "drone_id",
        "source_refs",
        "event_count",
        "highest_severity",
        "monitored_duration_s",
        "samples_processed",
        "human_review_required",
        "generated_by_skill",
        "skill_version"
      ]
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "timestamp",
          "event_type",
          "severity",
          "message",
          "measured_value",
          "threshold",
          "rule_id",
          "evidence_refs",
          "human_review_required",
          "generated_by_skill",
          "skill_version"
        ]
      }
    },
    "audit": {
      "type": "object",
      "required": [
        "skill_name",
        "skill_version",
        "input_refs",
        "output_refs",
        "tools_called",
        "rules_triggered",
        "human_review_required",
        "status",
        "created_at"
      ]
    }
  },
  "required": [
    "summary",
    "events",
    "audit"
  ]
}
